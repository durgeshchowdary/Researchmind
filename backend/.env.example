APP_NAME=ResearchMind API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_MINUTES=1440
FRONTEND_ORIGIN=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
CORS_ORIGIN_REGEX=^http://(localhost|127\.0\.0\.1):300[0-9]$
DATABASE_PATH=./data/researchmind.db
UPLOADS_DIR=./data/uploads
INDEX_DIR=./data/indexes
TEMP_DIR=./data/tmp
SEED_DIR=./data/seed
CHUNK_SIZE=850
CHUNK_OVERLAP=120
TOP_K_DEFAULT=8
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
SEMANTIC_MIN_SCORE=0.2
SEMANTIC_RESULT_LIMIT_MULTIPLIER=3
ASK_MIN_GROUNDED_SCORE=0.35
ASK_MIN_SUPPORTED_TERMS=1
LLM_TIMEOUT_SECONDS=45
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=
HYBRID_BM25_WEIGHT=0.55
HYBRID_SEMANTIC_WEIGHT=0.45
TITLE_MATCH_WEIGHT=0.25
ASYNC_INDEXING_ENABLED=true
REDIS_URL=redis://localhost:6379/0
RERANKING_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
EVALUATION_DATASET_PATH=./data/eval/eval_dataset.json
