{
  "build": {
    "builder": "NIXPACKS",
    "providers": ["python"],
    "buildCommand": "python3 -m pip install -r backend/requirements.txt"
  },
  "deploy": {
    "startCommand": "cd backend; python3 -m uvicorn app.main:app --host 0.0.0.0 --port $PORT",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}